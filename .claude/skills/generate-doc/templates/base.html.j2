<!doctype html>
<html lang="{{ meta.lang | default('en') }}">
<head>
<meta charset="utf-8">
<title>{{ meta.title }}</title>
<script>window.PagedConfig = { auto: true, after: () => {
  // Paged.js paints the @bottom-right page number as generated (::after) content,
  // which browsers never expose via textContent/getComputedStyle (spec behavior,
  // not a bug) - correct on screen, invisible to DOM introspection (used by
  // render_doc's chrome/report checks). Mirror the resolved number into a hidden,
  // real text node in the footer boxes so it stays inspectable regardless of
  // which box a selector finds first; skip pages where document.css turned the
  // footer off (the cover, via @page :first).
  document.querySelectorAll(".pagedjs_page").forEach((pg) => {
    const n = pg.getAttribute("data-page-number");
    const gate = pg.querySelector(".pagedjs_margin-bottom-right .pagedjs_margin-content");
    if (!gate || getComputedStyle(gate, "::after").content === "none") return;
    [".pagedjs_margin-bottom-right", ".pagedjs_margin-bottom-center"].forEach((sel) => {
      const box = pg.querySelector(sel + " .pagedjs_margin-content");
      if (!box) return;
      const mark = document.createElement("span");
      // Paged.js forces `.pagedjs_margin-content > *` to display:block, which
      // beats the `[hidden]` UA rule's specificity - use an inline style instead.
      mark.style.cssText = "display:none";
      mark.textContent = "Page " + n;
      box.appendChild(mark);
    });
  });
  // Running header TITLE (top-right): document.css sets it via
  // `@top-right { content: string(runhead) }` + `string-set: runhead ...`, but
  // in Paged.js 0.4.3 that margin box's `string()` resolution is unreliable
  // (see the .has-doc-title rule in document.css for the full story) and never
  // paints correctly on its own - unlike `element(brandmark)` (top-left logo),
  // which works. Inject the real title as a visible DOM text node instead,
  // same as the footer mirror above but visible: it inherits the box's
  // font-size/letter-spacing/text-transform/color from the `@top-right` rule
  // since those are inherited CSS properties.
  const isHandbook = document.body.classList.contains("handbook");
  // Each chapter heading tagged with the page it landed on, in document order -
  // used to resolve the handbook's "current chapter" per page below.
  const chapters = isHandbook
    ? Array.from(document.querySelectorAll("main h1")).map((h) => ({
        text: h.textContent.trim(),
        page: Number(h.closest(".pagedjs_page").getAttribute("data-page-number")),
      }))
    : [];
  document.querySelectorAll(".pagedjs_page").forEach((pg) => {
    const n = Number(pg.getAttribute("data-page-number"));
    const box = pg.querySelector(".pagedjs_margin-top-right .pagedjs_margin-content");
    // skip the cover: @page :first sets @top-right { content: none }
    if (!box || getComputedStyle(box, "::after").content === "none") return;
    let title = document.title;
    if (isHandbook) {
      const current = chapters.filter((c) => c.page <= n).pop();
      if (current) title = current.text;
    }
    const span = document.createElement("span");
    // the top-right margin box auto-sizes to its content's intrinsic width;
    // without nowrap it wraps one word per line instead of growing wider.
    span.style.cssText = "white-space:nowrap;";
    span.textContent = title;
    box.appendChild(span);
    // marks this box for document.css's has-doc-title rule, which suppresses
    // Paged.js's own (stale/invisible) string(runhead) ::after text so it
    // cannot double up with the span above once the box gains width.
    box.classList.add("has-doc-title");
  });
  window.__PAGED_DONE = true;
} };</script>
<style>{{ brand_css | safe }}</style>
<style>{{ document_css | safe }}</style>
</head>
<body class="doc {{ meta.template }} lang-{{ meta.lang | default('en') }}">
  <div class="brandmark">{{ logo | safe }}</div>
  {% include "partials/cover-" ~ meta.template ~ ".html.j2" %}
  <nav class="toc-page">
    <h2 class="toc-title">{{ 'Nội dung' if meta.lang == 'vi' else 'Contents' }}</h2>
    {{ toc_html | safe }}
  </nav>
  <main>{{ body_html | safe }}</main>
  <script>{{ pagedjs_js | safe }}</script>
</body>
</html>
